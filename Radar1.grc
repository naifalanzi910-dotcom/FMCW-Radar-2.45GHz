- name: epy_block_6
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\n\nclass\
      \ music_doa_block(gr.basic_block):\n    def __init__(self, center_freq=2.45e9,\
      \ rx_spacing_m=None, num_sources=1):\n        gr.basic_block.__init__(\n   \
      \         self,\n            name=\"music_doa_block\",\n            in_sig=None,\n\
      \            out_sig=None\n        )\n\n        self.c = 3e8\n        self.fc\
      \ = float(center_freq)\n        self.lam = self.c / self.fc\n        self.d\
      \ = self.lam / 2 if rx_spacing_m is None else float(rx_spacing_m)\n        self.num_sources\
      \ = int(num_sources)\n\n        self.message_port_register_in(pmt.intern(\"\
      rdm_per_rx\"))\n        self.message_port_register_out(pmt.intern(\"doa\"))\n\
      \        self.set_msg_handler(pmt.intern(\"rdm_per_rx\"), self.handle_msg)\n\
      \n    def publish_spectrum(self, ang_grid, spectrum, peak_angle=0.0, note=\"\
      \"):\n        meta = {\n            \"angles_deg\": ang_grid.tolist(),\n   \
      \         \"shape\": [1, len(spectrum)],\n            \"dtype\": \"float32\"\
      ,\n            \"peak_angle_deg\": float(peak_angle),\n            \"note\"\
      : note\n        }\n        msg = pmt.cons(\n            pmt.to_pmt(meta),\n\
      \            pmt.init_f32vector(len(spectrum), spectrum.astype(np.float32))\n\
      \        )\n        self.message_port_pub(pmt.intern(\"doa\"), msg)\n\n    def\
      \ handle_msg(self, msg):\n        meta = pmt.to_python(pmt.car(msg))\n     \
      \   vec = np.array(pmt.f32vector_elements(pmt.cdr(msg)), dtype=np.float32)\n\
      \n        if \"shape\" not in meta:\n            ang_grid = np.arange(-90.0,\
      \ 90.25, 0.25, dtype=np.float32)\n            spectrum = np.zeros_like(ang_grid,\
      \ dtype=np.float32)\n            self.publish_spectrum(ang_grid, spectrum, 0.0,\
      \ \"Missing shape metadata\")\n            return\n\n        arr = vec.reshape(meta[\"\
      shape\"])   # expected shape: [num_rx, range_bins, doppler_bins] or similar\n\
      \n        if arr.ndim < 3:\n            ang_grid = np.arange(-90.0, 90.25, 0.25,\
      \ dtype=np.float32)\n            spectrum = np.zeros_like(ang_grid, dtype=np.float32)\n\
      \            self.publish_spectrum(ang_grid, spectrum, 0.0, \"Input array has\
      \ wrong dimensions\")\n            return\n\n        num_rx = arr.shape[0]\n\
      \        ang_grid = np.arange(-90.0, 90.25, 0.25, dtype=np.float32)\n\n    \
      \    # Fallback mode for one RX: publish flat line\n        if num_rx < 2:\n\
      \            spectrum = np.zeros_like(ang_grid, dtype=np.float32)\n        \
      \    self.publish_spectrum(ang_grid, spectrum, 0.0, \"\")\n            return\n\
      \n        # Normal MUSIC path\n        # Pick strongest range-doppler cell from\
      \ summed power\n        summed = np.sum(arr, axis=0)   # [range, doppler]\n\
      \        peak_idx = np.unravel_index(np.argmax(summed), summed.shape)\n    \
      \    rbin, dbin = peak_idx\n\n        # Snapshot vector across antennas\n  \
      \      x = arr[:, rbin, dbin].astype(np.complex64).reshape(-1, 1)\n\n      \
      \  # Covariance\n        Rxx = x @ x.conj().T\n\n        eigvals, eigvecs =\
      \ np.linalg.eigh(Rxx)\n        idx = np.argsort(eigvals)[::-1]\n        eigvecs\
      \ = eigvecs[:, idx]\n\n        nsrc = min(self.num_sources, num_rx - 1)\n  \
      \      En = eigvecs[:, nsrc:]\n\n        rx_pos = np.arange(num_rx, dtype=np.float32)\
      \ * self.d\n        spectrum = np.zeros(len(ang_grid), dtype=np.float32)\n\n\
      \        for i, ang in enumerate(ang_grid):\n            th = np.deg2rad(ang)\n\
      \            sv = np.exp(1j * 2 * np.pi * rx_pos * np.sin(th) / self.lam).reshape(-1,\
      \ 1)\n            denom = np.real((sv.conj().T @ (En @ En.conj().T) @ sv).item())\n\
      \            spectrum[i] = 1.0 / max(denom, 1e-12)\n\n        if np.max(spectrum)\
      \ > 0:\n            spectrum = spectrum / np.max(spectrum)\n\n        peak_angle\
      \ = ang_grid[np.argmax(spectrum)]\n        self.publish_spectrum(ang_grid, spectrum,\
      \ peak_angle, \"Normal MUSIC\")"
    affinity: ''
    alias: ''
    center_freq: fc
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_sources: '1'
    rx_spacing_m: '0.0612'
  states:
    _io_cache: ('music_doa_block', 'music_doa_block', [('center_freq', '2450000000.0'),
      ('rx_spacing_m', 'None'), ('num_sources', '1')], [('rdm_per_rx', 'message',
      1)], [('doa', 'message', 1)], '', ['num_sources'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [824, 372.0]
    rotation: 0
    state: enabled
- name: epy_block_7
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ cfar2d_block(gr.basic_block):\n    def __init__(self, tr=8, td=8, gr_=1, gd=1,\
      \ pfa=1e-6):\n        gr.basic_block.__init__(self,\n            name=\"cfar2d_block\"\
      ,\n            in_sig=None,\n            out_sig=None)\n\n        self.tr =\
      \ int(tr)\n        self.td = int(td)\n        self.gr = int(gr_)\n        self.gd\
      \ = int(gd)\n        self.pfa = float(pfa)\n\n        self.message_port_register_in(pmt.intern(\"\
      rdm\"))\n        self.message_port_register_out(pmt.intern(\"cfar\"))\n    \
      \    self.set_msg_handler(pmt.intern(\"rdm\"), self.handle_msg)\n\n    def handle_msg(self,\
      \ msg):\n        meta = pmt.to_python(pmt.car(msg))\n        vec = np.array(pmt.f32vector_elements(pmt.cdr(msg)),\
      \ dtype=np.float32)\n        RDM = vec.reshape(meta[\"shape\"])\n\n        rows,\
      \ cols = RDM.shape\n        CFAR = np.zeros_like(RDM, dtype=np.uint8)\n\n  \
      \      N = (2*(self.tr+self.gr)+1)*(2*(self.td+self.gd)+1) - (2*self.gr+1)*(2*self.gd+1)\n\
      \        alpha = N * (self.pfa ** (-1.0 / N) - 1.0)\n\n        for i in range(self.tr\
      \ + self.gr, rows - (self.tr + self.gr)):\n            for j in range(self.td\
      \ + self.gd, cols - (self.td + self.gd)):\n                w = RDM[i-(self.tr+self.gr):i+(self.tr+self.gr)+1,\n\
      \                        j-(self.td+self.gd):j+(self.td+self.gd)+1].copy()\n\
      \n                w[self.tr:self.tr+2*self.gr+1, self.td:self.td+2*self.gd+1]\
      \ = 0.0\n                noise = np.sum(w) / N\n                thr = alpha\
      \ * noise\n\n                if RDM[i, j] > thr:\n                    CFAR[i,\
      \ j] = 1\n\n        new_meta = dict(meta)\n        new_meta[\"shape\"] = list(CFAR.shape)\n\
      \n        self.message_port_pub(\n            pmt.intern(\"cfar\"),\n      \
      \      pmt.cons(pmt.to_pmt(new_meta), pmt.init_u8vector(CFAR.size, CFAR.ravel().tolist()))\n\
      \        )"
    affinity: ''
    alias: ''
    comment: ''
    gd: '1'
    gr_: '1'
    maxoutbuf: '0'
    minoutbuf: '0'
    pfa: 1e-6
    td: '8'
    tr: '8'
  states:
    _io_cache: ('cfar2d_block', 'cfar2d_block', [('tr', '8'), ('td', '8'), ('gr_',
      '1'), ('gd', '1'), ('pfa', '1e-06')], [('rdm', 'message', 1)], [('cfar', 'message',
      1)], '', ['gd', 'pfa', 'td', 'tr'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1264, 36.0]
    rotation: 0
    state: enabled
- name: epy_block_8
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ doppler_fft_block(gr.basic_block):\n    def __init__(self, chirps_per_frame=1024,\
      \ range_fft_len=1024, doppler_fft_len=2048):\n        gr.basic_block.__init__(self,\n\
      \            name=\"doppler_fft_block\",\n            in_sig=None,\n       \
      \     out_sig=None)\n\n        self.nc = int(chirps_per_frame)\n        self.nr\
      \ = int(range_fft_len)\n        self.nd = int(doppler_fft_len)\n        self.win\
      \ = np.hanning(self.nc).astype(np.float32)\n\n        self.message_port_register_in(pmt.intern(\"\
      rng_cube\"))\n        self.message_port_register_out(pmt.intern(\"rdm\"))\n\
      \        self.message_port_register_out(pmt.intern(\"rdm_per_rx\"))\n      \
      \  self.set_msg_handler(pmt.intern(\"rng_cube\"), self.handle_msg)\n\n    def\
      \ handle_msg(self, msg):\n        meta = pmt.to_python(pmt.car(msg))\n     \
      \   vec = np.array(pmt.c32vector_elements(pmt.cdr(msg)), dtype=np.complex64)\n\
      \        cube = vec.reshape(meta[\"shape\"])   # [rx, chirp, range]\n\n    \
      \    num_rx = cube.shape[0]\n        rdm_per_rx = np.zeros((num_rx, self.nr,\
      \ self.nd), dtype=np.float32)\n\n        for rx in range(num_rx):\n        \
      \    tmp = cube[rx] * self.win[:, None]\n            dop = np.fft.fftshift(np.fft.fft(tmp,\
      \ n=self.nd, axis=0), axes=0)  # [doppler, range]\n            rdm_per_rx[rx]\
      \ = np.abs(dop.T).astype(np.float32)                   # [range, doppler]\n\n\
      \        rdm = np.sum(rdm_per_rx, axis=0)\n        p = rdm ** 2\n        if\
      \ np.max(p) > 0:\n            p /= np.max(p)\n\n        meta_rdm = dict(meta)\n\
      \        meta_rdm[\"shape\"] = list(p.shape)\n        meta_rdm[\"doppler_fft_len\"\
      ] = self.nd\n\n        self.message_port_pub(\n            pmt.intern(\"rdm\"\
      ),\n            pmt.cons(pmt.to_pmt(meta_rdm), pmt.init_f32vector(p.size, p.ravel()))\n\
      \        )\n\n        meta_rx = dict(meta)\n        meta_rx[\"shape\"] = list(rdm_per_rx.shape)\n\
      \        self.message_port_pub(\n            pmt.intern(\"rdm_per_rx\"),\n \
      \           pmt.cons(pmt.to_pmt(meta_rx), pmt.init_f32vector(rdm_per_rx.size,\
      \ rdm_per_rx.ravel()))\n        )"
    affinity: ''
    alias: ''
    chirps_per_frame: ch
    comment: ''
    doppler_fft_len: vfl
    maxoutbuf: '0'
    minoutbuf: '0'
    range_fft_len: rfl
  states:
    _io_cache: ('doppler_fft_block', 'doppler_fft_block', [('chirps_per_frame', '1024'),
      ('range_fft_len', '1024'), ('doppler_fft_len', '2048')], [('rng_cube', 'message',
      1)], [('rdm_per_rx', 'message', 1), ('rdm', 'message', 1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [936, 76.0]
    rotation: 0
    state: enabled
- name: epy_block_9
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\n\nclass\
      \ matched_filter_block(gr.basic_block):\n    \"\"\"\n    Message-based matched\
      \ filter block for FMCW radar datacube.\n\n    Input message:\n      datacube\
      \  -> complex cube with shape (1, chirps_per_frame, samples_per_chirp)\n\n \
      \   Output message:\n      datacube  -> filtered complex cube with same shape\n\
      \n    This block generates the transmit reference chirp internally and applies\n\
      \    a matched filter along the fast-time (samples-per-chirp) axis.\n    \"\"\
      \"\n\n    def __init__(self,\n                 sample_rate=30e6,\n         \
      \        bandwidth=25e6,\n                 samples_per_chirp=900,\n        \
      \         chirps_per_frame=128,\n                 amplitude=1.0):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"matched_filter_block\",\n           \
      \ in_sig=None,\n            out_sig=None\n        )\n\n        self.sample_rate\
      \ = float(sample_rate)\n        self.bandwidth = float(bandwidth)\n        self.samples_per_chirp\
      \ = int(samples_per_chirp)\n        self.chirps_per_frame = int(chirps_per_frame)\n\
      \        self.amplitude = float(amplitude)\n\n        self.message_port_register_in(pmt.intern(\"\
      datacube\"))\n        self.message_port_register_out(pmt.intern(\"datacube\"\
      ))\n        self.set_msg_handler(pmt.intern(\"datacube\"), self.handle_msg)\n\
      \n        # build reference chirp\n        self._build_reference()\n\n    def\
      \ _build_reference(self):\n        t = np.arange(self.samples_per_chirp, dtype=np.float64)\
      \ / self.sample_rate\n        Tc = self.samples_per_chirp / self.sample_rate\n\
      \        k = self.bandwidth / Tc\n\n        tx_chirp = self.amplitude * np.exp(1j\
      \ * np.pi * k * t * t)\n        self.tx_chirp = tx_chirp.astype(np.complex64)\n\
      \n        # matched filter impulse response: time-reversed conjugate\n     \
      \   self.h = np.conj(self.tx_chirp[::-1]).astype(np.complex64)\n\n        #\
      \ FFT size for fast convolution\n        self.nfft = 1\n        needed = self.samples_per_chirp\
      \ + len(self.h) - 1\n        while self.nfft < needed:\n            self.nfft\
      \ *= 2\n\n        self.H = np.fft.fft(self.h, n=self.nfft)\n\n    def _matched_filter_1d(self,\
      \ x):\n        X = np.fft.fft(x, n=self.nfft)\n        y = np.fft.ifft(X * self.H)\n\
      \n        # full convolution length\n        y = y[:len(x) + len(self.h) - 1]\n\
      \n        # center crop back to original length\n        start = (len(self.h)\
      \ - 1) // 2\n        end = start + len(x)\n        y_same = y[start:end]\n\n\
      \        return y_same.astype(np.complex64)\n\n    def handle_msg(self, msg):\n\
      \        meta = pmt.car(msg)\n        data = pmt.cdr(msg)\n\n        meta_py\
      \ = pmt.to_python(meta)\n        shape = meta_py[\"shape\"]\n\n        vec =\
      \ np.array(pmt.c32vector_elements(data), dtype=np.complex64)\n        cube =\
      \ vec.reshape(shape)\n\n        # expected current shape: (1, chirps_per_frame,\
      \ samples_per_chirp)\n        out = np.zeros_like(cube, dtype=np.complex64)\n\
      \n        num_rx = cube.shape[0]\n        num_chirps = cube.shape[1]\n\n   \
      \     for rx in range(num_rx):\n            for ch in range(num_chirps):\n \
      \               out[rx, ch, :] = self._matched_filter_1d(cube[rx, ch, :])\n\n\
      \        out_meta = dict(meta_py)\n        out_meta[\"matched_filter\"] = True\n\
      \n        out_pmt = pmt.init_c32vector(out.size, out.ravel().tolist())\n   \
      \     self.message_port_pub(\n            pmt.intern(\"datacube\"),\n      \
      \      pmt.cons(pmt.to_pmt(out_meta), out_pmt)\n        )"
    affinity: ''
    alias: ''
    amplitude: '1'
    bandwidth: BW
    chirps_per_frame: ch
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: sr
    samples_per_chirp: spc
  states:
    _io_cache: ('matched_filter_block', 'matched_filter_block', [('sample_rate', '30000000.0'),
      ('bandwidth', '25000000.0'), ('samples_per_chirp', '900'), ('chirps_per_frame',
      '128'), ('amplitude', '1.0')], [('datacube', 'message', 1)], [('datacube', 'message',
      1)], '\n    Message-based matched filter block for FMCW radar datacube.\n\n    Input
      message:\n      datacube  -> complex cube with shape (1, chirps_per_frame, samples_per_chirp)\n\n    Output
      message:\n      datacube  -> filtered complex cube with same shape\n\n    This
      block generates the transmit reference chirp internally and applies\n    a matched
      filter along the fast-time (samples-per-chirp) axis.\n    ', ['amplitude', 'bandwidth',
      'chirps_per_frame', 'sample_rate', 'samples_per_chirp'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [544, 492.0]
    rotation: 0
    state: enabled
