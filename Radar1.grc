- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\n\nclass fmcw_chirp_src(gr.sync_block):\n\
      \    def __init__(self, sample_rate=30e6, bandwidth=25e6, samples_per_chirp=900,\
      \ amplitude=0.5):\n        gr.sync_block.__init__(self,\n            name=\"\
      fmcw_chirp_src\",\n            in_sig=None,\n            out_sig=[np.complex64])\n\
      \n        self.fs = float(sample_rate)\n        self.bw = float(bandwidth)\n\
      \        self.ns = int(samples_per_chirp)\n        self.amp = float(amplitude)\n\
      \n        self.tc = self.ns / self.fs\n        self.k = self.bw / self.tc\n\n\
      \        t = np.arange(self.ns, dtype=np.float64) / self.fs\n        phase =\
      \ np.pi * self.k * t * t\n        self.chirp = (self.amp * np.exp(1j * phase)).astype(np.complex64)\n\
      \        self.idx = 0\n\n    def work(self, input_items, output_items):\n  \
      \      out = output_items[0]\n        n = len(out)\n        for i in range(n):\n\
      \            out[i] = self.chirp[self.idx]\n            self.idx += 1\n    \
      \        if self.idx >= self.ns:\n                self.idx = 0\n        return\
      \ n"
    affinity: ''
    alias: ''
    amplitude: '0.7'
    bandwidth: BW
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: sr
    samples_per_chirp: spc
  states:
    _io_cache: ('fmcw_chirp_src', 'fmcw_chirp_src', [('sample_rate', '30000000.0'),
      ('bandwidth', '25000000.0'), ('samples_per_chirp', '900'), ('amplitude', '0.5')],
      [], [('0', 'complex', 1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [56, 172.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport matplotlib.pyplot as plt\nfrom gnuradio\
      \ import gr\nimport pmt\n\n\nclass rdm_display_block(gr.basic_block):\n    \"\
      \"\"\n    Display Range-Doppler Map with physical axes:\n      x-axis: velocity\
      \ (m/s)\n      y-axis: range (m)\n    \"\"\"\n\n    def __init__(self,\n   \
      \              sample_rate=30e6,\n                 center_freq=2.45e9,\n   \
      \              bandwidth=25e6,\n                 samples_per_chirp=900,\n  \
      \               chirps_per_frame=128,\n                 chirp_period=0.0,\n\
      \                 title=\"Range-Doppler Map\",\n                 update_every=1):\n\
      \        gr.basic_block.__init__(\n            self,\n            name=\"rdm_display_block\"\
      ,\n            in_sig=None,\n            out_sig=None\n        )\n\n       \
      \ self.sample_rate = float(sample_rate)\n        self.center_freq = float(center_freq)\n\
      \        self.bandwidth = float(bandwidth)\n        self.samples_per_chirp =\
      \ int(samples_per_chirp)\n        self.chirps_per_frame = int(chirps_per_frame)\n\
      \        self.chirp_period = float(chirp_period)   # if 0, use Tc = samples_per_chirp\
      \ / sample_rate\n        self.title = title\n        self.update_every = int(update_every)\n\
      \        self.msg_count = 0\n\n        self.c = 3e8\n        self.lam = self.c\
      \ / self.center_freq\n\n        self.message_port_register_in(pmt.intern(\"\
      rdm\"))\n        self.set_msg_handler(pmt.intern(\"rdm\"), self.handle_msg)\n\
      \n        plt.ion()\n        self.fig, self.ax = plt.subplots()\n        self.im\
      \ = None\n        self.cbar = None\n\n    def _axes(self, range_bins, doppler_bins):\n\
      \        # Range\n        range_res = self.c / (2.0 * self.bandwidth)\n    \
      \    rng_axis = np.arange(range_bins, dtype=np.float64) * range_res\n\n    \
      \    # Velocity\n        if self.chirp_period > 0:\n            Tc = self.chirp_period\n\
      \        else:\n            Tc = self.samples_per_chirp / self.sample_rate\n\
      \n        max_vel = self.lam / (4.0 * Tc)\n        dop_axis = np.linspace(-max_vel,\
      \ max_vel, doppler_bins, dtype=np.float64)\n\n        return rng_axis, dop_axis\n\
      \n    def handle_msg(self, msg):\n        self.msg_count += 1\n        if self.msg_count\
      \ % self.update_every != 0:\n            return\n\n        meta = pmt.to_python(pmt.car(msg))\n\
      \        data = np.array(pmt.f32vector_elements(pmt.cdr(msg)), dtype=np.float32)\n\
      \        arr = data.reshape(meta[\"shape\"])   # expected shape: [range_bins,\
      \ doppler_bins]\n\n        range_bins, doppler_bins = arr.shape\n        rng_axis,\
      \ dop_axis = self._axes(range_bins, doppler_bins)\n\n        arr_db = 20.0 *\
      \ np.log10(np.maximum(arr, 1e-12))\n\n        extent = [dop_axis[0], dop_axis[-1],\
      \ rng_axis[0], rng_axis[-1]]\n\n        if self.im is None:\n            self.im\
      \ = self.ax.imshow(\n                arr_db,\n                extent=extent,\n\
      \                aspect='auto',\n                origin='lower'\n          \
      \  )\n            self.cbar = self.fig.colorbar(self.im, ax=self.ax)\n     \
      \   else:\n            self.im.set_data(arr_db)\n            self.im.set_extent(extent)\n\
      \            self.im.set_clim(vmin=np.min(arr_db), vmax=np.max(arr_db))\n\n\
      \        self.ax.set_title(self.title)\n        self.ax.set_xlabel(\"Velocity\
      \ (m/s)\")\n        self.ax.set_ylabel(\"Range (m)\")\n\n        self.fig.canvas.draw()\n\
      \        self.fig.canvas.flush_events()"
    affinity: ''
    alias: ''
    bandwidth: BW
    center_freq: fc
    chirp_period: spc/sr
    chirps_per_frame: ch
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: sr
    samples_per_chirp: spc
    title: '''Range-Doppler Map'''
    update_every: '1'
  states:
    _io_cache: '(''rdm_display_block'', ''rdm_display_block'', [(''sample_rate'',
      ''30000000.0''), (''center_freq'', ''2450000000.0''), (''bandwidth'', ''25000000.0''),
      (''samples_per_chirp'', ''900''), (''chirps_per_frame'', ''128''), (''chirp_period'',
      ''0.0''), (''title'', "''Range-Doppler Map''"), (''update_every'', ''1'')],
      [(''rdm'', ''message'', 1)], [], ''\n    Display Range-Doppler Map with physical
      axes:\n      x-axis: velocity (m/s)\n      y-axis: range (m)\n    '', [''bandwidth'',
      ''center_freq'', ''chirp_period'', ''chirps_per_frame'', ''sample_rate'', ''samples_per_chirp'',
      ''title'', ''update_every''])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1048, 252.0]
    rotation: 0
    state: enabled
- name: epy_block_2
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport matplotlib.pyplot as plt\nfrom gnuradio\
      \ import gr\nimport pmt\n\n\nclass cfar_display_block(gr.basic_block):\n   \
      \ \"\"\"\n    Display CFAR detection map with physical axes:\n      x-axis:\
      \ velocity (m/s)\n      y-axis: range (m)\n    \"\"\"\n\n    def __init__(self,\n\
      \                 sample_rate=30e6,\n                 center_freq=2.45e9,\n\
      \                 bandwidth=25e6,\n                 samples_per_chirp=900,\n\
      \                 chirps_per_frame=128,\n                 chirp_period=0.0,\n\
      \                 title=\"CFAR Detection Map\",\n                 update_every=1):\n\
      \        gr.basic_block.__init__(\n            self,\n            name=\"cfar_display_block\"\
      ,\n            in_sig=None,\n            out_sig=None\n        )\n\n       \
      \ self.sample_rate = float(sample_rate)\n        self.center_freq = float(center_freq)\n\
      \        self.bandwidth = float(bandwidth)\n        self.samples_per_chirp =\
      \ int(samples_per_chirp)\n        self.chirps_per_frame = int(chirps_per_frame)\n\
      \        self.chirp_period = float(chirp_period)   # if 0, use Tc = samples_per_chirp\
      \ / sample_rate\n        self.title = title\n        self.update_every = int(update_every)\n\
      \        self.msg_count = 0\n\n        self.c = 3e8\n        self.lam = self.c\
      \ / self.center_freq\n\n        self.message_port_register_in(pmt.intern(\"\
      cfar\"))\n        self.set_msg_handler(pmt.intern(\"cfar\"), self.handle_msg)\n\
      \n        plt.ion()\n        self.fig, self.ax = plt.subplots()\n        self.im\
      \ = None\n        self.cbar = None\n\n    def _axes(self, range_bins, doppler_bins):\n\
      \        # Range\n        range_res = self.c / (2.0 * self.bandwidth)\n    \
      \    rng_axis = np.arange(range_bins, dtype=np.float64) * range_res\n\n    \
      \    # Velocity\n        if self.chirp_period > 0:\n            Tc = self.chirp_period\n\
      \        else:\n            Tc = self.samples_per_chirp / self.sample_rate\n\
      \n        max_vel = self.lam / (4.0 * Tc)\n        dop_axis = np.linspace(-max_vel,\
      \ max_vel, doppler_bins, dtype=np.float64)\n\n        return rng_axis, dop_axis\n\
      \n    def handle_msg(self, msg):\n        self.msg_count += 1\n        if self.msg_count\
      \ % self.update_every != 0:\n            return\n\n        meta = pmt.to_python(pmt.car(msg))\n\
      \        data = np.array(pmt.u8vector_elements(pmt.cdr(msg)), dtype=np.uint8)\n\
      \        arr = data.reshape(meta[\"shape\"])   # expected shape: [range_bins,\
      \ doppler_bins]\n\n        range_bins, doppler_bins = arr.shape\n        rng_axis,\
      \ dop_axis = self._axes(range_bins, doppler_bins)\n\n        extent = [dop_axis[0],\
      \ dop_axis[-1], rng_axis[0], rng_axis[-1]]\n\n        if self.im is None:\n\
      \            self.im = self.ax.imshow(\n                arr,\n             \
      \   extent=extent,\n                aspect='auto',\n                origin='lower',\n\
      \                vmin=0,\n                vmax=1\n            )\n          \
      \  self.cbar = self.fig.colorbar(self.im, ax=self.ax)\n        else:\n     \
      \       self.im.set_data(arr)\n            self.im.set_extent(extent)\n    \
      \        self.im.set_clim(vmin=0, vmax=1)\n\n        self.ax.set_title(self.title)\n\
      \        self.ax.set_xlabel(\"Velocity (m/s)\")\n        self.ax.set_ylabel(\"\
      Range (m)\")\n\n        self.fig.canvas.draw()\n        self.fig.canvas.flush_events()"
    affinity: ''
    alias: ''
    bandwidth: BW
    center_freq: fc
    chirp_period: spc/sr
    chirps_per_frame: ch
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    sample_rate: sr
    samples_per_chirp: spc
    title: '''CFAR Detection Map'''
    update_every: '1'
  states:
    _io_cache: '(''cfar_display_block'', ''cfar_display_block'', [(''sample_rate'',
      ''30000000.0''), (''center_freq'', ''2450000000.0''), (''bandwidth'', ''25000000.0''),
      (''samples_per_chirp'', ''900''), (''chirps_per_frame'', ''128''), (''chirp_period'',
      ''0.0''), (''title'', "''CFAR Detection Map''"), (''update_every'', ''1'')],
      [(''cfar'', ''message'', 1)], [], ''\n    Display CFAR detection map with physical
      axes:\n      x-axis: velocity (m/s)\n      y-axis: range (m)\n    '', [''bandwidth'',
      ''center_freq'', ''chirp_period'', ''chirps_per_frame'', ''sample_rate'', ''samples_per_chirp'',
      ''title'', ''update_every''])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1272, 212.0]
    rotation: 0
    state: enabled
- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nimport matplotlib.pyplot as plt\nfrom gnuradio\
      \ import gr\nimport pmt\n\n\nclass music_display_block(gr.basic_block):\n  \
      \  def __init__(self, title=\"Music Spectrum\", update_every=1):\n        gr.basic_block.__init__(\n\
      \            self,\n            name=\"music_display_block\",\n            in_sig=None,\n\
      \            out_sig=None\n        )\n\n        self.title = title\n       \
      \ self.update_every = int(update_every)\n        self.counter = 0\n\n      \
      \  self.message_port_register_in(pmt.intern(\"doa\"))\n        self.set_msg_handler(pmt.intern(\"\
      doa\"), self.handle_msg)\n\n        plt.ion()\n        self.fig, self.ax = plt.subplots()\n\
      \        self.line, = self.ax.plot([], [])\n        self.ax.set_title(self.title)\n\
      \        self.ax.set_xlabel(\"Angle (deg)\")\n        self.ax.set_ylabel(\"\
      Spectrum\")\n        self.ax.grid(True)\n        self.fig.canvas.draw()\n  \
      \      self.fig.canvas.flush_events()\n\n    def handle_msg(self, msg):\n  \
      \      self.counter += 1\n        if self.counter % self.update_every != 0:\n\
      \            return\n\n        meta = pmt.to_python(pmt.car(msg))\n        vec\
      \ = np.array(pmt.f32vector_elements(pmt.cdr(msg)), dtype=np.float32)\n\n   \
      \     if \"angles_deg\" in meta:\n            x = np.array(meta[\"angles_deg\"\
      ], dtype=np.float32)\n        else:\n            x = np.arange(len(vec), dtype=np.float32)\n\
      \n        y = vec\n\n        if len(x) == 0 or len(y) == 0:\n            x =\
      \ np.array([-90.0, 90.0], dtype=np.float32)\n            y = np.array([0.0,\
      \ 0.0], dtype=np.float32)\n\n        self.line.set_data(x, y)\n        self.ax.set_xlim(float(np.min(x)),\
      \ float(np.max(x)))\n\n        ymin = float(np.min(y))\n        ymax = float(np.max(y))\n\
      \n        if abs(ymax - ymin) < 1e-9:\n            ymin -= 0.05\n          \
      \  ymax += 0.05\n\n        self.ax.set_ylim(ymin, ymax)\n\n        note = meta.get(\"\
      note\", \"\")\n        if note:\n            self.ax.set_title(f\"{self.title}\
      \ - {note}\")\n        else:\n            self.ax.set_title(self.title)\n\n\
      \        self.fig.canvas.draw()\n        self.fig.canvas.flush_events()"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    title: '''Music Spectrum'''
    update_every: '1'
  states:
    _io_cache: ('music_display_block', 'music_display_block', [('title', "'Music Spectrum'"),
      ('update_every', '1')], [('doa', 'message', 1)], [], '', ['title', 'update_every'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1256, 500.0]
    rotation: 0
    state: enabled
- name: epy_block_4
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\nclass\
      \ range_fft_block(gr.basic_block):\n    def __init__(self, samples_per_chirp=900,\
      \ chirps_per_frame=1024, range_fft_len=1024):\n        gr.basic_block.__init__(self,\n\
      \            name=\"range_fft_block\",\n            in_sig=None,\n         \
      \   out_sig=None)\n\n        self.ns = int(samples_per_chirp)\n        self.nc\
      \ = int(chirps_per_frame)\n        self.nfft = int(range_fft_len)\n        self.win\
      \ = np.hanning(self.ns).astype(np.float32)\n\n        self.message_port_register_in(pmt.intern(\"\
      datacube\"))\n        self.message_port_register_out(pmt.intern(\"rng_cube\"\
      ))\n        self.set_msg_handler(pmt.intern(\"datacube\"), self.handle_msg)\n\
      \n    def handle_msg(self, msg):\n        meta = pmt.to_python(pmt.car(msg))\n\
      \        vec = np.array(pmt.c32vector_elements(pmt.cdr(msg)), dtype=np.complex64)\n\
      \        cube = vec.reshape(meta[\"shape\"])\n\n        out = np.zeros((cube.shape[0],\
      \ self.nc, self.nfft), dtype=np.complex64)\n        for rx in range(cube.shape[0]):\n\
      \            tmp = cube[rx] * self.win[None, :]\n            out[rx] = np.fft.fft(tmp,\
      \ n=self.nfft, axis=1)\n\n        new_meta = dict(meta)\n        new_meta[\"\
      shape\"] = list(out.shape)\n        new_meta[\"range_fft_len\"] = self.nfft\n\
      \n        self.message_port_pub(\n            pmt.intern(\"rng_cube\"),\n  \
      \          pmt.cons(pmt.to_pmt(new_meta), pmt.init_c32vector(out.size, out.ravel()))\n\
      \        )"
    affinity: ''
    alias: ''
    chirps_per_frame: ch
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    range_fft_len: rfl
    samples_per_chirp: spc
  states:
    _io_cache: ('range_fft_block', 'range_fft_block', [('samples_per_chirp', '900'),
      ('chirps_per_frame', '1024'), ('range_fft_len', '1024')], [('datacube', 'message',
      1)], [('rng_cube', 'message', 1)], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [696, 124.0]
    rotation: 0
    state: enabled
- name: epy_block_5
  id: epy_block
  parameters:
    _source_code: "import numpy as np\nfrom gnuradio import gr\nimport pmt\n\n\nclass\
      \ radar_cube_builder(gr.sync_block):\n    \"\"\"\n    Real-time radar datacube\
      \ builder for:\n      input 0 = tx_ref\n      input 1 = rx0\n\n    Output message:\n\
      \      datacube\n\n    Datacube shape:\n      (1, chirps_per_frame, samples_per_chirp)\n\
      \    \"\"\"\n\n    def __init__(self, samples_per_chirp=900, chirps_per_frame=128,\
      \ dechirp=True):\n        self.samples_per_chirp = int(samples_per_chirp)\n\
      \        self.chirps_per_frame = int(chirps_per_frame)\n\n        if isinstance(dechirp,\
      \ str):\n            self.dechirp = dechirp.strip().lower() in (\"true\", \"\
      1\", \"yes\", \"on\")\n        else:\n            self.dechirp = bool(dechirp)\n\
      \n        self.frame_samples = self.samples_per_chirp * self.chirps_per_frame\n\
      \n        gr.sync_block.__init__(\n            self,\n            name=\"radar_cube_builder\"\
      ,\n            in_sig=[np.complex64, np.complex64],   # tx_ref, rx0\n      \
      \      out_sig=None\n        )\n\n        self.message_port_register_out(pmt.intern(\"\
      datacube\"))\n\n        self.tx_buf = np.zeros(0, dtype=np.complex64)\n    \
      \    self.rx_buf = np.zeros(0, dtype=np.complex64)\n\n    def work(self, input_items,\
      \ output_items):\n        tx = input_items[0]\n        rx = input_items[1]\n\
      \n        if len(tx) == 0 or len(rx) == 0:\n            return 0\n\n       \
      \ self.tx_buf = np.concatenate((self.tx_buf, tx))\n        self.rx_buf = np.concatenate((self.rx_buf,\
      \ rx))\n\n        while len(self.tx_buf) >= self.frame_samples and len(self.rx_buf)\
      \ >= self.frame_samples:\n            tx_frame = self.tx_buf[:self.frame_samples]\n\
      \            rx_frame = self.rx_buf[:self.frame_samples]\n\n            self.tx_buf\
      \ = self.tx_buf[self.frame_samples:]\n            self.rx_buf = self.rx_buf[self.frame_samples:]\n\
      \n            tx_chirps = tx_frame.reshape(self.chirps_per_frame, self.samples_per_chirp)\n\
      \            rx_chirps = rx_frame.reshape(self.chirps_per_frame, self.samples_per_chirp)\n\
      \n            cube = np.zeros(\n                (1, self.chirps_per_frame, self.samples_per_chirp),\n\
      \                dtype=np.complex64\n            )\n\n            if self.dechirp:\n\
      \                cube[0] = rx_chirps * np.conj(tx_chirps)\n            else:\n\
      \                cube[0] = rx_chirps\n\n            meta = pmt.to_pmt({\n  \
      \              \"shape\": list(cube.shape),\n                \"dtype\": \"complex64\"\
      ,\n                \"num_rx\": 1,\n                \"samples_per_chirp\": self.samples_per_chirp,\n\
      \                \"chirps_per_frame\": self.chirps_per_frame\n            })\n\
      \n            data = pmt.init_c32vector(\n                cube.size,\n     \
      \           cube.ravel().tolist()\n            )\n\n            msg = pmt.cons(meta,\
      \ data)\n            self.message_port_pub(pmt.intern(\"datacube\"), msg)\n\n\
      \        return min(len(tx), len(rx))"
    affinity: ''
    alias: ''
    chirps_per_frame: ch
    comment: ''
    dechirp: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    samples_per_chirp: spc
